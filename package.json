{
  "name": "vaultgate",
  "version": "1.0.0",
  "private": true,
  "description": "VaultGate — self-hosted AI agent desktop app",
  "author": "VaultGate",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev -p 7483",
    "build": "next build",
    "start": "next start -p 7483",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c blue,magenta \"next dev -p 7483\" \"npm run electron:compile && wait-on tcp:7483 && cross-env VAULTGATE_DEV=1 electron .\"",
    "electron:build": "next build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-symbols/icons": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.525.0",
    "mammoth": "^1.12.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.6",
    "sql.js": "^1.12.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.vaultgate.app",
    "productName": "VaultGate",
    "files": [
      "dist-electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "src/skills/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
