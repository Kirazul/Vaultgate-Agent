# ============================================================
# VaultGate — environment defaults (first-run seed only)
# Copy to .env.local. Runtime changes are made in-app (Settings)
# and stored in the local SQLite database, not here.
# ============================================================

# Default OpenAI-compatible API endpoint (user can change in Settings)
OPENAI_API_ENDPOINT=

# API key for the endpoint (leave empty for local models like Ollama)
OPENAI_API_KEY=

# Optional default model id. Leave empty to fetch + pick in the UI.
DEFAULT_MODEL=

# Where local data lives in dev. In the packaged app this is the
# Electron userData directory automatically.
VAULTGATE_DATA_DIR=./.data
